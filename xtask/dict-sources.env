# Sources for the binary dictionary indexes.
#
# Read by `xtask/src/main.rs` (via include_str!) and by
# `server/Dockerfile` (sourced as a shell env file). Keeping both
# consumers pointed at one file means the Dockerfile can pre-fetch
# the inputs in its own cacheable layer without duplicating URLs.
#
# Each source has two keys:
#   <NAME>_URL — gzipped upstream URL
#   <NAME>_OUT — filename of the decompressed file inside the
#                workspace root (what the xtask `build-*` commands
#                expect as their --input path)

JMDICT_URL=http://ftp.edrdg.org/pub/Nihongo/JMdict_e.gz
JMDICT_OUT=JMdict_e

KANJIDIC_URL=http://ftp.edrdg.org/pub/Nihongo/kanjidic2.xml.gz
KANJIDIC_OUT=kanjidic2

EXAMPLES_URL=http://ftp.edrdg.org/pub/Nihongo/examples.utf.gz
EXAMPLES_OUT=examples.utf
