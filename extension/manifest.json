{
  "manifest_version": 3,
  "name": "Yomeru",
  "version": "0.8.1",
  "description": "Hover to look up Japanese words with dictionary and SRS vocabulary memory.",
  "browser_specific_settings": {
    "gecko": {
      "id": "{7ed2e7e9-a883-42ef-b811-2f069d8b612c}",
      "strict_min_version": "143.0",
      "update_url": "https://github.com/F4r3n/Yomeru/releases/latest/download/updates.json",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "scripts": [
      "dist/background.js"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "_generated/jmdict-wasm/jmdict_wasm.js",
        "_generated/jmdict-wasm/jmdict_wasm_bg.wasm",
        "_generated/srs-wasm/srs_wasm.js",
        "_generated/srs-wasm/srs_wasm_bg.wasm",
        "_generated/kanjidic-wasm/kanjidic_wasm.js",
        "_generated/kanjidic-wasm/kanjidic_wasm_bg.wasm",
        "_generated/examples-wasm/examples_wasm.js",
        "_generated/examples-wasm/examples_wasm_bg.wasm",
        "data/jmdict.bin",
        "data/kanjidic.bin",
        "data/examples.bin",
        "_generated/yomeru-extension/yomeru_extension.js",
        "_generated/yomeru-extension/yomeru_extension_bg.wasm"
      ],
      "matches": [
        "*://*/*"
      ]
    }
  ],
  "action": {
    "default_popup": "options.html",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "128": "icons/icon.svg"
  }
}
