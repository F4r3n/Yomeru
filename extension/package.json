{
  "name": "yomeru-ext",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:content && npm run build:app",
    "build:content": "vite build --config vite.content.config.ts",
    "build:app": "vite build",
    "dev:content": "vite build --config vite.content.config.ts --watch",
    "dev:app": "vite build --watch",
    "dev:run": "web-ext run",
    "test": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^25.6.1",
    "fake-indexeddb": "^6.2.5",
    "svelte": "^5.55.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "version": "0.4.1"
}
