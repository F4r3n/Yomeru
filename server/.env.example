# Copy this file to `.env` and fill in your values.
# docker compose reads `.env` automatically; the server reads these vars at startup.

# --- HTTP ---
YOMERU_PORT=8080

# --- Storage ---
# Path inside the container. /data is a mounted volume in docker-compose.yml.
YOMERU_DB_PATH=/data/yomeru.db

# --- Dict data ---
# Directory containing jmdict.bin / kanjidic.bin / examples.bin.
# Populated by the `yomeru-dicts` builder service into the shared
# `yomeru-dicts` named volume; the server image mounts that volume at
# /usr/share/yomeru-server/dicts and points YOMERU_DATA_DIR there by
# default. Override here only if you mount the dict files somewhere
# else.
#YOMERU_DATA_DIR=/usr/share/yomeru-server/dicts

# --- Dev mode ---
# Set to 1 for local development:
#   * /api/auth/request skips SMTP and prints the OTP to stdout
#   * /api/sync accepts requests without a Bearer token
# Leave unset (or =0) in production. SMTP_HOST / SMTP_FROM are also
# optional while this is on.
#YOMERU_DEV_MODE=1

# --- SMTP (required unless YOMERU_DEV_MODE=1) ---
YOMERU_SMTP_HOST=smtp.example.com
YOMERU_SMTP_PORT=587
YOMERU_SMTP_FROM=noreply@example.com

# Leave blank if your SMTP relay does not require auth.
YOMERU_SMTP_USER=
YOMERU_SMTP_PASS=
