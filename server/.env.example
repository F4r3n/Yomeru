# Copy this file to `.env` and fill in your values.
# docker compose reads `.env` automatically; the server reads these vars at startup.

# --- HTTP ---
YOMERU_PORT=8080

# --- Storage ---
# Path inside the container. /data is a mounted volume in docker-compose.yml.
YOMERU_DB_PATH=/data/yomeru.db

# --- SMTP (required) ---
YOMERU_SMTP_HOST=smtp.example.com
YOMERU_SMTP_PORT=587
YOMERU_SMTP_FROM=noreply@example.com

# Leave blank if your SMTP relay does not require auth.
YOMERU_SMTP_USER=
YOMERU_SMTP_PASS=
