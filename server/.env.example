# Copy this file to `.env` and fill in your values.
# docker compose reads `.env` automatically; the server reads these vars at startup.

# --- HTTP ---
YOMERU_PORT=8080

# --- Storage ---
# Path inside the container. /data is a mounted volume in docker-compose.yml.
YOMERU_DB_PATH=/data/yomeru.db

# --- Dict data ---
# Directory containing jmdict.bin / kanjidic.bin / examples.bin.
# Build them with `cargo xtask build-all`, then bind-mount that directory
# at /data/dicts (see docker-compose.yml). Required at server startup.
YOMERU_DATA_DIR=/data/dicts

# --- SMTP (required) ---
YOMERU_SMTP_HOST=smtp.example.com
YOMERU_SMTP_PORT=587
YOMERU_SMTP_FROM=noreply@example.com

# Leave blank if your SMTP relay does not require auth.
YOMERU_SMTP_USER=
YOMERU_SMTP_PASS=
